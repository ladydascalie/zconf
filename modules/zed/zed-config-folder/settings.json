{
	"ssh_connections": [
  {
   "host": "mysql-prod-primary",
   "args": [],
   "projects": [
    {
     "paths": [
      "/root"
     ]
    },
    {
     "paths": [
      "/tmp/./"
     ]
    }
   ]
  },
  {
   "host": "mysql-prod-replica",
   "args": [],
   "projects": []
  }
 ],
 "agent_buffer_font_size": 14.0,
	"agent_ui_font_size": 14.0,
	"cli_default_open_behavior": "existing_window",
	"collaboration_panel": {
		"dock": "right",
	},
	"git_panel": {
		"dock": "right",
		"tree_view": false,
	},
	"file_finder": {
		"include_ignored": "all",
	},
	"buffer_line_height": "comfortable",
	"outline_panel": {
		"dock": "right",
		"auto_fold_dirs": true,
	},
	"agent_servers": {
		"github-copilot": {
			"type": "registry",
		},
	},
	"redact_private_values": false,
	"git": {
		"inline_blame": {
			"show_commit_summary": false,
		},
	},
	"tabs": {
		"show_diagnostics": "errors",
		"file_icons": true,
		"git_status": true,
	},
	"cursor_shape": "bar",
	"edit_predictions": {
		"provider": "zed",
		"mode": "eager",
	},
	"project_panel": {
		"dock": "right",
		"entry_spacing": "standard",
	},
	"language_models": {},
	"agent": {
		"inline_assistant_model": {
			"provider": "copilot_chat",
			"model": "gpt-4o",
			"enable_thinking": false,
		},
		"dock": "left",
		"play_sound_when_agent_done": "always",
		"default_model": {
			"provider": "zed.dev",
			"model": "claude-sonnet-4-5",
		},
		"commit_message_model": {
			"provider": "copilot_chat",
			"model": "claude-sonnet-4",
		},
	},
	"icon_theme": {
		"mode": "dark",
		"light": "Catppuccin Macchiato",
		"dark": "Catppuccin Macchiato",
	},
	"ui_font_family": "MonoLisaCustom Nerd Font",
	"ui_font_weight": 400,
	"ui_font_size": 14.0,
	"bottom_dock_layout": "contained",
	"buffer_font_family": "MonoLisaCustom Nerd Font",
	"buffer_font_size": 16.0,
	"buffer_font_weight": 350.0,
	"line_indicator_format": "long",
	"terminal": {
		"cursor_shape": "bar",
		"toolbar": {
			"breadcrumbs": false,
		},
		"font_family": "MonoLisaCustom Nerd Font",
	},
	"hard_tabs": true,
	"tab_size": 8,
	"wrap_guides": [80, 120],
	"minimap": { "show": "always" },
	"theme": {
		"mode": "dark",
		"light": "One Light",
		"dark": "Nightfox - opaque",
	},
	"vim_mode": true,
	"lsp": {
		"golangci-lint": {
			"initialization_options": {
				"command": [
					"golangci-lint",
					"run",
					"--output.json.path=stdout",
					"--show-stats=false",
				],
			},
		},
		"gopls": {
			"initialization_options": {
				"build.buildFlags": ["-tags=mage,integration"],
				"formatting.gofumpt": true,
				"analyses": {
					"unusedvariable": true,
					"useany": true,
					"modernize": true,
					"ST1000": false,
				},
				"staticcheck": true,
				"hints": {
					"assignVariableTypes": false,
					"compositeLiteralFields": true,
					"compositeLiteralTypes": true,
					"constantValues": true,
					"functionTypeParameters": true,
					"parameterNames": true,
					"rangeVariableTypes": true,
				},
			},
		},
		"templ": {},
	},
	"context_servers": {},
	"languages": {
		"Go": {
			"formatter": "language_server",
			"tab_size": 8,
		},
		"YAML": {
			"tab_size": 2,
		},
		"JSONC": {
			"tab_size": 4,
		},
		"Templ": {
			"language_servers": [
				"templ",
				"tailwindcss-language-server",
				"vscode-html-language-server",
				"emmet-language-server",
			],
		},
	},
}
